# ===========================================
# Vanilla Trace — Variables d'environnement
# Copier vers .env (backend) et .env.local (frontend)
# ===========================================

# --- Backend (.env) ---

# Hedera
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=0.0.XXXXXX
HEDERA_OPERATOR_KEY=302e...
HEDERA_TOKEN_ID=0.0.YYYYYY
HEDERA_TOPIC_ID=0.0.ZZZZZZ
HEDERA_CONTRACT_ID=0.0.WWWWWW

# Mirror Node
MIRROR_NODE_URL=https://testnet.mirrornode.hedera.com

# Base de données
DATABASE_URL=postgresql://user:pass@localhost:5432/vanillatrace

# IPFS
PINATA_API_KEY=...
PINATA_SECRET_KEY=...

# Sécurité
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# --- Frontend (.env.local) ---
# NEXT_PUBLIC_API_URL=http://localhost:3001
# NEXT_PUBLIC_HEDERA_NETWORK=testnet
# NEXT_PUBLIC_HASHCONNECT_APP_NAME=VanillaTrace
# NEXT_PUBLIC_HASHCONNECT_PROJECT_ID=   # WalletConnect Cloud (optionnel ; si vide = mode démo)
